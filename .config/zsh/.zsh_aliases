# ================================
# 🚀 Matt Configs
# ================================

# --- Quick Navigation (auto ls with details) ---
alias ecv='cd ~/dev/ecv && ll'
alias lakbaygo='cd ~/dev/lakbaygo && ll'
alias ark='cd ~/dev/ark && ll'
alias betterbacolod='cd ~/dev/betterbacolod && ll'
alias cs='open -a "Cursor"'
alias ws='open -a "Windsurf"'
# --- Config Shortcuts ---
alias conf='nvim $ZDOTDIR/.zshrc'             # main zsh config
alias gconf='nvim ~/.config/zsh/.matt_greeting.sh'
alias aconf='nvim ~/.config/zsh/.zsh_aliases'
alias sshconf='nvim ~/.ssh/config'
# --- AWS Config Shortcuts ---
alias awsconf='nvim ~/.aws/config'
alias awscred='nvim ~/.aws/credentials'

# --- Reload & Helpers ---
alias rld='source $ZDOTDIR/.zshrc && echo "Reloaded zsh . . . "'
alias h='help'
alias mhelp='source ~/.config/zsh/.matt_greeting.sh'

# --- bat (better cat) ---
alias cat='bat --paging=never'
alias catp='bat'                    # cat with paging

# --- eza (better ls) ---
alias ls='eza --icons'
alias ll='eza --icons -lh --git'    # detailed + git status
alias la='eza --icons -lah --git'   # detailed + hidden files
alias lt='eza --icons --tree -L 2'  # tree view 2 levels

# --- fzf shortcuts ---
alias fh='history | fzf'            # fuzzy search history
alias ff='fzf --preview "bat --color=always {}"'  # fuzzy find file with preview

# --- Git Shortcuts ---
alias gs='git status'       # compact status
alias ga='git add .'         # add all changes
alias gc='git commit -m'        # commit with message
alias gca='git commit -am'      # add & commit with message
alias gp='git push'             # push current branch
alias gpl='git pull'            # pull latest
alias gl='git log --oneline --graph --decorate --all'  # nice log
alias gco='git checkout'        # switch branch
alias gb='git branch'           # list branches
alias gcb='git checkout -b'     # create + switch new branch
