# -------------------------------
# Matt's Paths
# -------------------------------

# Homebrew
export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/opt/homebrew}"
export PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$PATH"

# Secrets (gitignored — tokens, API keys)
[ -f ~/.config/zsh/.zsh_secrets ] && source ~/.config/zsh/.zsh_secrets

# Local bin (claude, uv, etc.)
export PATH="$HOME/.local/bin:$PATH"

# uv
[ -f "$HOME/.local/bin/env" ] && source "$HOME/.local/bin/env"

# Flutter
[ -d "$HOME/FlutterDev/flutter/bin" ] && export PATH="$PATH:$HOME/FlutterDev/flutter/bin"

# Node.js (NVM)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Android SDK
export ANDROID_HOME="$HOME/Library/Android/sdk"
for d in emulator tools tools/bin platform-tools; do
  [ -d "$ANDROID_HOME/$d" ] && export PATH="$PATH:$ANDROID_HOME/$d"
done

# Dart pub cache
[ -d "$HOME/.pub-cache/bin" ] && export PATH="$PATH:$HOME/.pub-cache/bin"

# Windsurf
[ -d "$HOME/.codeium/windsurf/bin" ] && export PATH="$HOME/.codeium/windsurf/bin:$PATH"

# Docker completions
[ -d "$HOME/.docker/completions" ] && fpath=($HOME/.docker/completions $fpath)

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# Rust
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# FVM
[ -d "$HOME/.fvm_flutter/bin" ] && export PATH="$HOME/.fvm_flutter/bin:$PATH"

## [Completion]
[ -f "$HOME/.dart-cli-completion/zsh-config.zsh" ] && source "$HOME/.dart-cli-completion/zsh-config.zsh"
## [/Completion]
