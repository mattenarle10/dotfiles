// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark"
  },
  "theme_overrides": {
    "Ayu Dark": {
      "background.appearance": "blurred",
      "background": "#11111BE8",
      "surface.background": "#181825E8",
      "elevated_surface.background": "#1E1E2EF0",
      "panel.background": "#181825E8",
      "title_bar.background": "#11111BE8",
      "title_bar.inactive_background": "#11111BD9",
      "tab_bar.background": "#11111BE8",
      "tab.inactive_background": "#181825D9",
      "tab.active_background": "#1E1E2EF0",
      "toolbar.background": "#181825E8",
      "editor.background": "#11111BE8",
      "editor.gutter.background": "#11111BE8",
      "editor.subheader.background": "#181825E8",
      "editor.active_line.background": "#31324480",
      "editor.highlighted_line.background": "#31324466",
      "editor.line_number": "#6C7086",
      "editor.active_line_number": "#CDD6F4",
      "editor.wrap_guide": "#CDD6F41A",
      "terminal.background": "#11111BE8",
      "border": "#313244CC",
      "border.variant": "#31324499",
      "border.focused": "#89B4FA",
      "text": "#CDD6F4",
      "text.muted": "#A6ADC8",
      "icon": "#CDD6F4",
      "icon.muted": "#A6ADC8",
      "syntax": {
        "comment": {
          "font_style": "italic"
        },
        "comment.doc": {
          "font_style": "italic"
        }
      }
    }
  }
}
