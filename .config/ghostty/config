# Appearance
theme = "citruszest"
font-family = "MesloLGS Nerd Font Mono"
background-opacity = 0.91
background-opacity-cells = true
background-blur = 10
cursor-style = bar

# Window title
window-title-font-family = "MesloLGS Nerd Font Mono"
# Note: Tab title alignment (centering) is not configurable in Ghostty yet

# Window / rendering
window-vsync = true

# Window padding
window-padding-x = 8
window-padding-y = 6

# New tab position (current = next to active tab, end = at the end)
window-new-tab-position = current

# Faster scrolling (default is 3)
mouse-scroll-multiplier = 5

# Tab movement keybindings
# Move tab left
keybind = cmd+shift+left=move_tab:-1
# Move tab right
keybind = cmd+shift+right=move_tab:1

# Split/pane creation
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:left
keybind = cmd+shift+1=new_split:down
keybind = cmd+shift+2=new_split:up

# Split/pane navigation
keybind = cmd+option+left=goto_split:left
keybind = cmd+option+right=goto_split:right
keybind = cmd+option+up=goto_split:up
keybind = cmd+option+down=goto_split:down

# Close current pane/split
keybind = cmd+w=close_surface

keybind = shift+enter=text:\x1b\r
